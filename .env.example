NODE_ENV=development
HOST=0.0.0.0
PORT=3000
# 多个来源使用英文逗号分隔，留空表示本地开发阶段放开。
CORS_ORIGINS=
DB_HOST=192.168.1.132
DB_PORT=3306
DB_USER=root
# 示例文件不保存真实密码，实际运行请在 .env 中填写。
DB_PASSWORD=
DB_NAME=wss_image_relay
AUTH_TOKEN_SECRET=image-relay-dev-secret
# 默认使用仓库根目录下的 data/files，可按部署环境改成本地磁盘或挂载目录。
FILE_STORAGE_DIR=
# 仅在需要返回绝对地址时配置，留空则前端直接使用相对接口地址。
FILE_BASE_URL=
MAX_UPLOAD_SIZE_MB=50
